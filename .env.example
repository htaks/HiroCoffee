# Supabase CLI / GitHub Actions 用（.env にコピーして値を入れてください）
# .env は git に含めません

SUPABASE_ACCESS_TOKEN=

# 本番（project ref = URL のサブドメイン）
SUPABASE_PROJECT_REF_PRODUCTION=ytyllufahvcrmirxhlaf
SUPABASE_DB_PASSWORD_PRODUCTION=

# ステージング（hiro-coffee-stg 等を作成後に設定）
SUPABASE_PROJECT_REF_STAGING=
SUPABASE_DB_PASSWORD_STAGING=
# 任意: Dashboard の Connection string (URI) をそのまま（推奨・接続エラー時）
SUPABASE_DB_URL_STAGING=

# 本番（任意・接続エラー時）
SUPABASE_DB_URL_PRODUCTION=

# Edge Functions 共通 Secrets（両環境に同じ LINE 設定を反映）
LINE_LOGIN_CHANNEL_ID=2010226071
LINE_LOGIN_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
